# ---- 0G ----
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
OG_CHAIN_CHAIN_ID=16602
OG_CHAIN_PK=0x...
OG_STORAGE_ENDPOINT=https://indexer-storage-testnet.0g.ai
OG_COMPUTE_ENDPOINT=...

# Set to 1 to upload each newly-learned scar as a 0G Storage blob via
# uploadJsonToOG (returns rootHash + txHash). Default off — leaving it
# off means scars stay only in the local KV mirror; turning it on adds
# one on-chain tx per scar event.
OG_STORAGE_LIVE=1

# Set to 1 to call 0G Compute on every child boot for verifiable
# inference. Default off. The Galileo testnet faucet caps at 0.1 OG/day
# and the 0G Compute broker requires a 3 OG ledger minimum, so on
# testnet this typically emits 'compute.skip' events with a typed
# funding-gap error rather than landing a TEE-attested response. The
# integration is wired correctly; only the funding side is blocked.
OG_COMPUTE_LIVE=1

# ---- KeeperHub ----
# Org-scoped direct-execution API key (kh_...). Used by executeWorkflow
# in agents/src/execution/keeperhub.ts to fire workflows over MCP HTTP.
KEEPERHUB_KEY=...
# Workflow ids (override per env if you fork; otherwise the canonical
# production ids in keeperhub.ts/head.ts/consensus.ts are used).
HYDRA_KH_DEATH_WORKFLOW_ID=lcyuk85gh46defy5xaq8b
HYDRA_KH_TREASURY_WORKFLOW_ID=uybkmq5v2mpvgji7933ji
HYDRA_KH_SCAR_WORKFLOW_ID=up22dre1y0frp1pskrbuj
HYDRA_KH_HEARTBEAT_WORKFLOW_ID=6sdbtvyee2n0uihywyim3

# ---- AXL ----
# Base port for AXL nodes; head-N uses BASE + N
AXL_PORT_BASE=9002
AXL_BINARY_PATH=./axl/bin/axl

# ---- Anthropic (optional, for scar rule descriptions) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Contracts (0G Galileo testnet — paste from contracts deploy output) ----
HYDRA_REGISTRY=0x...
HYDRA_TREASURY=0x...
HYDRA_EXECUTOR=0x...
HYDRA_SCARS=0x...

# ---- Web ----
WEB_PORT=3000
SSE_BROKER_PORT=4000
